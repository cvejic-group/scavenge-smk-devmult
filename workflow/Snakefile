        ## individual subsample reports
        expand("results/reports/trs/{trait_set}/report_trs_{trait}_knn{n_neighbors}_bg{n_background}_sample{n_subsample}_rng{rseed}.html",
               trait_set="scavenge_yu_2022",
               trait=trait_sets['scavenge_yu_2022']['traits'].keys(),
               n_background=config['n_background'],
               n_neighbors=config['n_neighbors'],
               n_subsample=config['n_subsample_per_sample'],
