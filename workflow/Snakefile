configfile: "config/config.yaml"

import os
from sys import stderr

# print to stderr
def message(*args, **kwargs):
    print(*args, file=stderr, **kwargs)

# ensure tmp directory exists
os.makedirs(config['tmp_dir'], exist_ok=True)

# load sample data
message("[INFO] Checking trait set info...")
trait_sets = config['trait_sets']
for k, v in trait_sets.items():
    message(f"[INFO]   Trait set '{k}' with {len(v['traits'])} traits.")

wildcard_constraints:
    n_background="[0-9]+",
    n_neighbors="[0-9]+",
    n_subsample="[0-9]+",
    rseed="[0-9]+",
    trait="[^_]+"

