################################################################################
## AGGREGATE RESULTS
################################################################################

def get_trait_set_outputs_subsample(wildcards):
    if not wildcards.trait_set in trait_sets.keys():
        message(f"[Error] Trait set '{wildcards.trait_set}' not found!")
        message("Available trait sets:", *trait_sets.keys(), sep="\n")
        exit(1)
    
    return expand("results/trs/{trait_set}/df_trs_{trait}_knn{n_neighbors}_bg{n_background}_sample{n_subsample}_rng{rseed}.csv.gz",
                  trait_set=wildcards.trait_set,
                  trait=trait_sets[wildcards.trait_set]['traits'].keys(),
                  n_neighbors=wildcards.n_neighbors,
                  n_background=wildcards.n_background,
                  n_subsample=wildcards.n_subsample,
                  rseed=wildcards.rseed)

rule aggregate_trait_set_subsample:
    input:
        get_trait_set_outputs_subsample
    output:
        "results/trs/df_trs_{trait_set}_knn{n_neighbors}_bg{n_background}_sample{n_subsample}_rng{rseed}.csv.gz"
    threads: 1
    shell: 
        """
        set +o pipefail
        zcat {input[0]} | head -n 1 | gzip > {output}
        for csv in {input}; do
            zcat "$csv" | tail -n +2 | gzip >> {output}
        done
        """

def get_trait_set_outputs_full(wildcards):
    if not wildcards.trait_set in trait_sets.keys():
        message(f"[Error] Trait set '{wildcards.trait_set}' not found!")
        message("Available trait sets:", *trait_sets.keys(), sep="\n")
        exit(1)
    
    return expand("results/trs/{trait_set}/df_trs_{trait}_knn{n_neighbors}_bg{n_background}_rng{rseed}.csv.gz",
                  trait_set=wildcards.trait_set,
                  trait=trait_sets[wildcards.trait_set]['traits'].keys(),
                  n_neighbors=wildcards.n_neighbors,
                  n_background=wildcards.n_background,
                  rseed=wildcards.rseed)

rule aggregate_trait_set_full:
    input:
        get_trait_set_outputs_full
    output:
        "results/trs/df_trs_{trait_set}_knn{n_neighbors}_bg{n_background}_rng{rseed}.csv.gz"
