def get_trait_file(wildcards):
    if not wildcards.trait_set in trait_sets.keys():
        message(f"[Error] Trait set '{wildcards.trait_set}' not found!")
        message("Available trait sets:", *trait_sets.keys(), sep="\n")
        exit(1)
    trait_set = trait_sets[wildcards.trait_set]
    base_path = trait_set['base_path']

    if not wildcards.trait in trait_set['traits'].keys():
        message(f"[Error] Trait '{wildcards.trait}' not found in trait set '{wildcards.trait_set}'!")
        message("Available traits:", *trait_set['traits'].keys(), sep="\n")
        exit(1)
    
    file_name = trait_set['traits'][wildcards.trait]
    
    return f"{base_path}/{file_name}"

rule deviations_trait_subsample:
    input:
        se="results/se/subsamples/se_sample{n_subsample}_rng{rseed}.Rds",
        mat_bg="results/bg/mat_bg{n_background}_sample{n_subsample}_rng{rseed}.Rds",
        bed_trait=get_trait_file
    output:
        dev_trait="results/dev/{trait_set}/dev_{trait}_bg{n_background}_sample{n_subsample}_rng{rseed}.Rds"
    params:
        rseed=lambda wcs: wcs.rseed
    threads: 24
    conda: "envs/scavenge_r43.yaml"
    script: "scripts/compute_deviations_subsample.R"

